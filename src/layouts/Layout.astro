---
// import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "@/config";
import "@/styles/global.css";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.url);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `${title}`,
  image: `${socialImageURL}`,
  datePublished: `${pubDatetime?.toISOString()}`,
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: [
    {
      "@type": "Person",
      name: `${author}`,
      ...(profile && { url: profile }),
    },
  ],
};

const mask = "radial-gradient(circle, transparent, black)";
---

<!doctype html>
<html
  dir={SITE.dir}
  lang={`${SITE.lang ?? "en"}`}
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Load Font -->
    <!-- <Font
      cssVariable="--font-google-sans-code"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    /> -->

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    {
      // If PUBLIC_GOOGLE_SITE_VERIFICATION is set in the environment variable,
      // include google-site-verification tag in the heading
      // Learn more: https://support.google.com/webmasters/answer/9008080#meta_tag_verification&zippy=%2Chtml-tag
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    <ClientRouter />

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = ""; // "light" | "dark"
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
  </head>

  <body>
    <div
      class="pointer-events-none fixed inset-0 z-[-1] transition-opacity duration-1000 print:hidden"
      style={`mask-image: ${mask}; -webkit-mask-image: ${mask};`}
    >
      <canvas
        id="plum-canvas"
        transition:persist="plum-canvas"
        class="h-full w-full"></canvas>
    </div>

    <slot />

    <!-- Progress bar for page transitions -->
    <!-- transition:persist 确保在路由切换时 DOM 不会被销毁重置，从而保障动画平滑过渡 -->
    <div id="page-progress" transition:persist="progress-bar"></div>

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>

    <!-- Page transition lifecycle: persistent progress bar + dev‑mode simulated latency -->
    <script>
      // Astro's module scripts run exactly once per session, perfect for global event listeners.

      document.addEventListener("astro:before-preparation", event => {
        const progressEl = document.getElementById("page-progress");
        if (!progressEl) return;

        // Reset to 0 instantly without transition
        progressEl.className = "progress-reset";
        void progressEl.offsetWidth; // Force reflow to apply reset instantly

        // Start loading animation (0 -> 70% slowly)
        progressEl.className = "progress-start";

        // ----- Only in development: mimic random network latency -----
        if (import.meta.env.DEV) {
          const originalLoader = event.loader;
          event.loader = async () => {
            const delay = Math.random() * 800 + 400; // 400–1200ms random delay
            await new Promise(resolve => setTimeout(resolve, delay));
            await originalLoader();
          };
        }
        // --------------------------------------------------------------
      });

      document.addEventListener("astro:after-preparation", () => {
        const progressEl = document.getElementById("page-progress");
        if (progressEl) {
          // Switch to complete class (70% -> 100% quickly)
          progressEl.className = "progress-complete";
        }
      });

      document.addEventListener("astro:page-load", () => {
        const progressEl = document.getElementById("page-progress");
        if (progressEl && progressEl.classList.contains("progress-complete")) {
          // Wait 300ms for the scaleX(1) complete animation to finish physically, then fade out
          setTimeout(() => {
            // Check if it's still completed (prevents bugs if user clicks rapidly)
            if (progressEl.classList.contains("progress-complete")) {
              progressEl.className = "progress-hidden";
            }
          }, 300);
        }
      });
    </script>

    <script>
      /**
       * Plum Blossom Effect
       * Adapted from Anthony Fu's antfu.me (MIT License)
       * Source: https://github.com/antfu/antfu.me/blob/main/src/components/ArtPlum.vue
       */

      let animationFrameId: number;

      function initPlumBlossom() {
        const canvas = document.getElementById(
          "plum-canvas"
        ) as HTMLCanvasElement | null;
        if (!canvas) return;

        if (animationFrameId) cancelAnimationFrame(animationFrameId);

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const r180 = Math.PI;
        const r90 = Math.PI / 2;
        const r15 = Math.PI / 12;
        const color = "#88888825";
        const MIN_BRANCH = 30;
        const len = 6;

        let size = { width: window.innerWidth, height: window.innerHeight };
        let steps: (() => void)[] = [];
        let prevSteps: (() => void)[] = [];
        let lastTime = performance.now();
        const interval = 1000 / 40;

        function initCanvas() {
          size = { width: window.innerWidth, height: window.innerHeight };
          const dpr = window.devicePixelRatio || 1;

          canvas!.style.width = `${size.width}px`;
          canvas!.style.height = `${size.height}px`;
          canvas!.width = size.width * dpr;
          canvas!.height = size.height * dpr;
          ctx!.scale(dpr, dpr);
        }

        function polar2cart(x = 0, y = 0, r = 0, theta = 0) {
          const dx = r * Math.cos(theta);
          const dy = r * Math.sin(theta);
          return [x + dx, y + dy];
        }

        function step(
          x: number,
          y: number,
          rad: number,
          counter: { value: number } = { value: 0 }
        ) {
          const length = Math.random() * len;
          counter.value += 1;

          const [nx, ny] = polar2cart(x, y, length, rad);

          ctx!.beginPath();
          ctx!.moveTo(x, y);
          ctx!.lineTo(nx, ny);
          ctx!.stroke();

          const rad1 = rad + Math.random() * r15;
          const rad2 = rad - Math.random() * r15;

          if (
            nx < -100 ||
            nx > size.width + 100 ||
            ny < -100 ||
            ny > size.height + 100
          )
            return;

          const rate = counter.value <= MIN_BRANCH ? 0.8 : 0.5;

          if (Math.random() < rate)
            steps.push(() => step(nx, ny, rad1, counter));
          if (Math.random() < rate)
            steps.push(() => step(nx, ny, rad2, counter));
        }

        function frame(currentTime: number) {
          if (currentTime - lastTime >= interval) {
            lastTime = currentTime;
            prevSteps = steps;
            steps = [];

            if (!prevSteps.length) {
              cancelAnimationFrame(animationFrameId);
              return;
            }

            prevSteps.forEach(i => {
              if (Math.random() < 0.5) steps.push(i);
              else i();
            });
          }
          animationFrameId = requestAnimationFrame(frame);
        }

        function randomMiddle() {
          return Math.random() * 0.6 + 0.2;
        }

        function start() {
          initCanvas();
          ctx!.clearRect(0, 0, canvas!.width, canvas!.height);

          ctx!.lineWidth = 1;
          ctx!.strokeStyle = color;

          prevSteps = [];
          steps = [
            () => step(randomMiddle() * size.width, -5, r90),
            () => step(randomMiddle() * size.width, size.height + 5, -r90),
            () => step(-5, randomMiddle() * size.height, 0),
            () => step(size.width + 5, randomMiddle() * size.height, r180),
          ];

          if (size.width < 500) steps = steps.slice(0, 2);

          animationFrameId = requestAnimationFrame(frame);
        }

        start();
      }

      document.addEventListener("astro:page-load", initPlumBlossom);
    </script>
  </body>
</html>
