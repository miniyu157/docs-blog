---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import "dayjs/locale/zh-cn";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);
dayjs.locale("zh-cn");

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
} = Astro.props;

const effectiveTz = postTimezone || SITE.timezone;

const pubTzDatetime = dayjs(pubDatetime).tz(effectiveTz);
const modTzDatetime = modDatetime
  ? dayjs(modDatetime).tz(effectiveTz)
  : null;

const isModified = modTzDatetime ? modTzDatetime.isAfter(pubTzDatetime) : false;

const pubIsoDatetime = pubTzDatetime.toISOString();
const pubFallback = pubTzDatetime.format("YYYY年M月D日 HH:mm");

let modIsoDatetime = "";
let modFallback = "";

if (isModified && modTzDatetime) {
  modIsoDatetime = modTzDatetime.toISOString();
  modFallback = modTzDatetime.format("YYYY年M月D日 HH:mm");
}
---

<div
  class:list={["flex items-center gap-x-2 opacity-80", className]}
  data-relative-time-tz={effectiveTz}
>
  <time
    datetime={pubIsoDatetime}
    data-fallback={pubFallback}
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
  >
    {pubFallback}
  </time>

  {
    isModified && (
      <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
        (修订: <time datetime={modIsoDatetime} data-fallback={modFallback}>{modFallback}</time>)
      </span>
    )
  }
</div>

<script>
  function initRelativeTime() {
    const containers = document.querySelectorAll("[data-relative-time-tz]");
    if (containers.length === 0) return;

    const lang = "zh-CN";

    type DateParts = {
      year: number;
      month: number;
      day: number;
      hour: number;
      minute: number;
    };

    function getParts(date: Date, tz: string): DateParts {
      const fmt = new Intl.DateTimeFormat(lang, {
        timeZone: tz,
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      });
      const parts: DateParts = { year: 0, month: 0, day: 0, hour: 0, minute: 0 };
      fmt.formatToParts(date).forEach((p) => {
        const key = p.type as keyof DateParts;
        if (key in parts) {
          parts[key] = parseInt(p.value, 10);
        }
      });
      return parts;
    }

    const now = new Date();

    containers.forEach((container) => {
      const tz = container.getAttribute("data-relative-time-tz") || "Asia/Shanghai";
      const times = container.querySelectorAll("time[datetime]");

      times.forEach((el) => {
        const iso = el.getAttribute("datetime");
        if (!iso) return;

        const target = new Date(iso);
        const tp = getParts(target, tz);
        const np = getParts(now, tz);

        const targetDayStart = Date.UTC(tp.year, tp.month - 1, tp.day);
        const nowDayStart = Date.UTC(np.year, np.month - 1, np.day);
        const diffDays = Math.floor((targetDayStart - nowDayStart) / 86400000);
        const diffYears = tp.year - np.year;

        const timeStr = `${String(tp.hour).padStart(2, "0")}:${String(tp.minute).padStart(2, "0")}`;
        const diffMinutes = Math.floor((now.getTime() - target.getTime()) / 60000);

        let text;
        if (diffDays === 0) {
          if (diffMinutes >= 0 && diffMinutes < 1) {
            text = "刚刚";
          } else if (diffMinutes >= 1 && diffMinutes < 60) {
            text = `${diffMinutes}分钟前`;
          } else {
            text = `今天 ${timeStr}`;
          }
        } else if (diffDays === -1) {
          text = `昨天 ${timeStr}`;
        } else if (diffDays === -2) {
          text = `前天 ${timeStr}`;
        } else if (diffDays === 1) {
          text = `明天 ${timeStr}`;
        } else if (diffDays === 2) {
          text = `后天 ${timeStr}`;
        } else {
          const dateStr = `${tp.month}月${tp.day}日`;
          if (diffYears === 0) {
            text = `${dateStr} ${timeStr}`;
          } else if (diffYears === 1) {
            text = `明年${dateStr}`;
          } else if (diffYears === -1) {
            text = `去年${dateStr}`;
          } else {
            text = `${tp.year}年${dateStr}`;
          }
        }

        el.textContent = text;
      });
    });
  }

  initRelativeTime();
</script>
